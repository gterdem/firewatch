# FireWatch deploy configuration — copy to deploy/.env and adjust.
#
#   cp deploy/.env.example deploy/.env
#
# Every value below has a safe built-in default in docker-compose.yml, so a
# .env file is OPTIONAL for the default profile — create one only to override
# a default (or to configure the lean profile). No secrets belong in this file.

# Host port for the nginx dashboard surface (the ONLY host-exposed port).
FW_HOST_PORT=8080

# Enable local-AI scoring (true/false). Rules-only scoring still works when false.
FIREWATCH_AI_ENABLED=true

# Inference model name (pulled into the inference runtime).
FIREWATCH_OLLAMA_MODEL=qwen2.5:3b

# Inference endpoint. Default profile (Ollama) value shown below.
# The lean profile (llama.cpp) overrides this to the llama-server endpoint —
# see deploy/README.md for the exact lean value.
FIREWATCH_OLLAMA_BASE_URL=http://ollama:11434

# --- lean profile only (llama.cpp + an operator-supplied GGUF model) ---
# Host path to the .gguf model file (mounted into the llama container):
#GGUF_HOST_PATH=/path/to/model.gguf
# GGUF filename as seen inside the container:
#MODEL_FILE=model.gguf
