{
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(rm -rf*)",
      "Bash(curl* | bash)",
      "Bash(curl* | sh)",
      "Bash(wget* | bash)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/worktree-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-changed.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
