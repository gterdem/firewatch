# FireWatch deploy configuration — copy to deploy/.env and adjust.
#
#   cp deploy/.env.example deploy/.env
#
# Every value below has a safe built-in default in docker-compose.yml, so a
# .env file is OPTIONAL for the default profile — create one only to override
# a default (or to configure the lean profile). No secrets belong in this file.

# Host port for the nginx dashboard surface (the ONLY host-exposed port).
FW_HOST_PORT=8080

# Enable local-AI scoring (true/false). Rules-only scoring still works when false.
FIREWATCH_AI_ENABLED=true

# Inference model name (pulled into the inference runtime).
FIREWATCH_OLLAMA_MODEL=qwen2.5:3b

# Inference endpoint. Default profile (Ollama) value shown below.
# The lean profile (llama.cpp) overrides this to the llama-server endpoint —
# see deploy/README.md for the exact lean value.
FIREWATCH_OLLAMA_BASE_URL=http://ollama:11434

# --- lean profile only (llama.cpp + an operator-supplied GGUF model) ---
# Host path to the .gguf model file (mounted into the llama container):
#GGUF_HOST_PATH=/path/to/model.gguf
# GGUF filename as seen inside the container:
#MODEL_FILE=model.gguf

# --- rules-only profile only (issue #4: zero AI footprint, no inference container) ---
# Both of the following are required together for `--profile rules-only`:
#FIREWATCH_AI_ENABLED=false
# FIREWATCH_OLLAMA_BASE_URL must ALSO be overridden to a loopback/RFC-1918
# literal — the default above names the `ollama` service's DNS entry, which
# does not exist under rules-only (no ollama container starts), and FireWatch's
# local-first validator (ADR-0022) fails closed on DNS resolution failure.
# It is never dialed once ai_enabled=false — see deploy/README.md.
#FIREWATCH_OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- host-logs override only (issue #5: deploy/docker-compose.host-logs.yml) ---
# Required if (and only if) you apply that override, to read the HOST's own
# journald/`/var/log` from inside the container. Set to the HOST's group GID
# for the group that owns the mounted logs — NOT a container-internal GID:
#   getent group systemd-journal   # journald path, e.g. systemd-journal:x:999:
#   getent group adm               # file-tail path (Debian/Ubuntu), e.g. adm:x:4:
# See deploy/README.md ("Reading the host's own logs") for the full write-up.
#FW_HOST_LOG_GID=999
